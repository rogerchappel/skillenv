{
  "name": "skillenv",
  "version": "0.1.0",
  "description": "Local-first preflight checks for agent skill runtime requirements.",
  "type": "module",
  "bin": {
    "skillenv": "./bin/skillenv.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check bin/skillenv.js",
    "smoke": "EXAMPLE_TOKEN=1 node bin/skillenv.js test/fixtures/ready/SKILL.md",
    "validate": "bash scripts/validate.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run validate && npm run package:smoke"
  },
  "keywords": [
    "agents",
    "skills",
    "preflight",
    "environment",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skillenv.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skillenv/issues"
  },
  "homepage": "https://github.com/rogerchappel/skillenv#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
